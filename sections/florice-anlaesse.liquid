<div
  class="florice-anlaesse color-{{ section.settings.color_scheme }} gradient"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="florice-anlaesse__scatter" aria-hidden="true">
    <span class="florice-anlaesse__sb florice-anlaesse__sb--l">{% render 'florice-bloom', type: 'peony' %}</span>
    <span class="florice-anlaesse__sb florice-anlaesse__sb--r">{% render 'florice-bloom', type: 'rose-stem' %}</span>
  </div>

  <div class="florice-anlaesse__head page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="florice-anlaesse__eyebrow">
        {% render 'florice-bloom', type: 'small' %}
        <span>{{ section.settings.eyebrow }}</span>
        {% render 'florice-bloom', type: 'small' %}
      </p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="florice-anlaesse__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}
      <div class="florice-anlaesse__intro rte">{{ section.settings.intro }}</div>
    {%- endif -%}
    <div class="florice-anlaesse__divider" aria-hidden="true">
      {% render 'florice-bloom', type: 'divider' %}
    </div>
  </div>

  {%- liquid
    assign fallback_coll_handle = section.settings.fallback_collection
    if fallback_coll_handle != blank
      assign fallback_coll = collections[fallback_coll_handle]
    else
      assign fallback_coll = nil
    endif
  -%}

  <div class="florice-anlaesse__grid page-width">
    {%- for block in section.blocks -%}
      {%- liquid
        assign icon_override = block.settings.icon
        assign title_lower = block.settings.title | downcase
        if icon_override != blank and icon_override != 'auto'
          assign tile_icon = icon_override
        elsif title_lower contains 'hochzeit'
          assign tile_icon = 'peony'
        elsif title_lower contains 'geschenk'
          assign tile_icon = 'wildflower'
        elsif title_lower contains 'trauer'
          assign tile_icon = 'branch'
        elsif title_lower contains 'wohnen' or title_lower contains 'deko'
          assign tile_icon = 'tulip'
        elsif title_lower contains 'liebe' or title_lower contains 'valentin'
          assign tile_icon = 'rose-stem'
        elsif title_lower contains 'sommer' or title_lower contains 'sonne'
          assign tile_icon = 'sunflower'
        else
          assign tile_icon = 'sprig'
        endif

        # resolve the product source for this tile
        assign tile_product = nil
        if block.settings.product != blank
          assign tile_product = all_products[block.settings.product]
        elsif fallback_coll != nil and fallback_coll.products_count > 0
          assign idx = forloop.index0 | modulo: fallback_coll.products_count
          assign tile_product = fallback_coll.products[idx]
        endif

        # decide effective image, title, link
        assign tile_link = block.settings.link
        assign tile_title = block.settings.title
        assign tile_product_image = nil
        if block.settings.image == blank and tile_product != nil
          assign tile_product_image = tile_product.featured_image
          if tile_link == blank
            assign tile_link = tile_product.url
          endif
          if section.settings.show_product_titles
            assign tile_title = tile_product.title
          endif
        endif

        if tile_link == blank
          assign tile_link = '/collections/all'
        endif

        # absolute unsplash fallback (only if neither image nor product available)
        if title_lower contains 'hochzeit'
          assign tile_fallback = 'https://images.unsplash.com/photo-1490750967868-88aa4486c946?auto=format&fit=crop&w=800&q=80'
        elsif title_lower contains 'geschenk'
          assign tile_fallback = 'https://images.unsplash.com/photo-1487530811176-3780de880c2d?auto=format&fit=crop&w=800&q=80'
        elsif title_lower contains 'trauer'
          assign tile_fallback = 'https://images.unsplash.com/photo-1518895949257-7621c3c786d7?auto=format&fit=crop&w=800&q=80'
        elsif title_lower contains 'wohnen' or title_lower contains 'deko'
          assign tile_fallback = 'https://images.unsplash.com/photo-1455659817273-f96807779a8a?auto=format&fit=crop&w=800&q=80'
        else
          assign tile_fallback = 'https://images.unsplash.com/photo-1487530811176-3780de880c2d?auto=format&fit=crop&w=800&q=80'
        endif
      -%}

      <a
        href="{{ tile_link }}"
        class="florice-anlaesse__tile florice-anlaesse__tile--{{ tile_icon }}"
        {{ block.shopify_attributes }}
      >
        <div class="florice-anlaesse__media">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 990px) 25vw, 50vw',
                widths: '375, 550, 750, 900',
                alt: tile_title
            }}
          {%- elsif tile_product_image != nil -%}
            {{
              tile_product_image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 990px) 25vw, 50vw',
                widths: '375, 550, 750, 900',
                alt: tile_title
            }}
          {%- else -%}
            <img src="{{ tile_fallback }}" alt="{{ tile_title | escape }} — Florice" loading="lazy">
          {%- endif -%}
          <span class="florice-anlaesse__number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          <span class="florice-anlaesse__floral" aria-hidden="true" data-bloom="{{ tile_icon }}">
            {% render 'florice-bloom', type: tile_icon %}
          </span>
        </div>
        <div class="florice-anlaesse__caption">
          <span class="florice-anlaesse__kicker">{{ block.settings.kicker | escape }}</span>
          <span class="florice-anlaesse__name">{{ tile_title | escape }}</span>
          <span class="florice-anlaesse__arrow" aria-hidden="true">→</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.florice-anlaesse {
  position: relative;
  overflow: hidden;
}

.florice-anlaesse__scatter {
  position: absolute;
  inset: 0;
  pointer-events: none;
  color: rgb(var(--color-foreground));
  z-index: 0;
}

.florice-anlaesse__sb {
  position: absolute;
  opacity: 0.14;
  display: block;
  width: 6rem;
}

.florice-anlaesse__sb--l {
  top: 8%;
  left: 3%;
  transform: rotate(-18deg);
}

.florice-anlaesse__sb--r {
  top: 6%;
  right: 3%;
  transform: rotate(22deg);
}

.florice-anlaesse__head,
.florice-anlaesse__grid {
  position: relative;
  z-index: 1;
}

@media screen and (max-width: 749px) {
  .florice-anlaesse__sb {
    width: 3.8rem;
    opacity: 0.1;
  }
}

.florice-anlaesse__head {
  text-align: center;
  max-width: 56rem;
  margin: 0 auto 5rem;
  padding: 0 2rem;
}

.florice-anlaesse__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 1.1rem;
  font-size: 1.1rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  margin: 0 0 1.5rem;
  opacity: 0.7;
  font-weight: 500;
}

.florice-anlaesse__eyebrow .florice-bloom {
  opacity: 0.55;
}

.florice-anlaesse__divider {
  margin: 1.8rem auto 0;
  opacity: 0.7;
}

.florice-anlaesse__title {
  font-family: var(--font-heading-family);
  font-weight: 300;
  font-size: clamp(3.4rem, 5vw, 5.6rem);
  line-height: 1.05;
  letter-spacing: -0.025em;
  margin: 0 0 2rem;
  word-break: keep-all;
  overflow-wrap: normal;
  hyphens: none;
}

.florice-anlaesse__title em {
  font-style: italic;
  font-weight: 300;
}

.florice-anlaesse__intro {
  font-size: 1.55rem;
  line-height: 1.6;
  opacity: 0.75;
  max-width: 42rem;
  margin: 0 auto;
}

.florice-anlaesse__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
}

.florice-anlaesse__tile {
  position: relative;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  background: transparent;
}

.florice-anlaesse__media {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: rgb(var(--color-foreground) / 0.06);
}

.florice-anlaesse__placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgb(var(--color-foreground));
  opacity: 0.32;
}

.florice-anlaesse__placeholder .florice-bloom {
  width: 55%;
  height: auto;
  max-width: 14rem;
}

.florice-anlaesse__floral {
  position: absolute;
  bottom: 1.4rem;
  right: 1.4rem;
  width: 4.2rem;
  height: 5.6rem;
  color: white;
  opacity: 0.9;
  filter: drop-shadow(0 1px 4px rgba(0,0,0,0.4));
  transition: transform 0.5s cubic-bezier(0.16, 0.84, 0.44, 1);
  pointer-events: none;
}

.florice-anlaesse__floral[data-bloom="lavender"] {
  width: 3rem;
}

.florice-anlaesse__floral[data-bloom="peony"],
.florice-anlaesse__floral[data-bloom="sunflower"] {
  width: 4.8rem;
}

.florice-anlaesse__tile:hover .florice-anlaesse__floral {
  transform: rotate(-8deg) translateY(-3px);
}

.florice-anlaesse__placeholder + .florice-anlaesse__number,
.florice-anlaesse__placeholder ~ .florice-anlaesse__floral {
  color: rgb(var(--color-foreground));
  text-shadow: none;
}

.florice-anlaesse__placeholder ~ .florice-anlaesse__floral {
  filter: none;
  opacity: 0.6;
}

.florice-anlaesse__media img,
.florice-anlaesse__media svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.9s cubic-bezier(0.16, 0.84, 0.44, 1);
}

.florice-anlaesse__tile:hover .florice-anlaesse__media img {
  transform: scale(1.04);
}

.florice-anlaesse__number {
  position: absolute;
  top: 1.2rem;
  left: 1.4rem;
  font-family: var(--font-heading-family);
  font-style: italic;
  font-size: 1.6rem;
  color: white;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
  letter-spacing: 0.05em;
}

.florice-anlaesse__caption {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: end;
  gap: 0.5rem 1rem;
  padding: 1.8rem 0.3rem 0;
  position: relative;
}

.florice-anlaesse__caption::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: rgb(var(--color-foreground) / 0.22);
}

.florice-anlaesse__kicker {
  grid-column: 1 / 2;
  grid-row: 1;
  font-size: 1rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  opacity: 0.6;
  font-weight: 500;
}

.florice-anlaesse__name {
  grid-column: 1 / 2;
  grid-row: 2;
  font-family: var(--font-heading-family);
  font-style: italic;
  font-weight: 300;
  font-size: 2.2rem;
  letter-spacing: -0.01em;
  line-height: 1.1;
}

.florice-anlaesse__arrow {
  grid-column: 2 / 3;
  grid-row: 2;
  font-size: 1.8rem;
  align-self: end;
  transition: transform 0.3s ease;
}

.florice-anlaesse__tile:hover .florice-anlaesse__arrow {
  transform: translateX(6px);
}

@media screen and (max-width: 989px) {
  .florice-anlaesse__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .florice-anlaesse__head {
    margin-bottom: 3.5rem;
  }
  .florice-anlaesse__name {
    font-size: 1.8rem;
  }
}

@media screen and (max-width: 480px) {
  .florice-anlaesse__grid {
    gap: 0.8rem;
  }
  .florice-anlaesse__floral {
    width: 3.4rem;
    height: 4.6rem;
    bottom: 1rem;
    right: 1rem;
  }
  .florice-anlaesse__floral[data-bloom="peony"],
  .florice-anlaesse__floral[data-bloom="sunflower"] {
    width: 3.8rem;
  }
  .florice-anlaesse__number {
    font-size: 1.4rem;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Florice Anlässe",
  "tag": "section",
  "class": "section section-florice-anlaesse",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Kopf"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Für jeden Moment"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Titel",
      "default": "Anlässe, die <em>bleiben.</em>"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro-Text",
      "default": "<p>Vier Sammlungen, jede mit eigener Stimmung. Wähle den Moment — wir wickeln die passende Blüte.</p>"
    },
    {
      "type": "header",
      "content": "Produkt-Auto-Fallback"
    },
    {
      "type": "collection",
      "id": "fallback_collection",
      "label": "Fallback-Collection",
      "info": "Wenn pro Kachel kein Bild und kein Produkt gepickt ist, werden Bilder, Titel und Links aus dieser Collection automatisch der Reihe nach gezogen."
    },
    {
      "type": "checkbox",
      "id": "show_product_titles",
      "label": "Produkt-Titel statt Anlass-Name zeigen",
      "info": "Wenn aktiv und ein Produkt verlinkt ist, zeigt die Kachel den Produkt-Titel an. Sonst bleibt der manuell gesetzte Anlass-Name.",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farb-Schema",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding oben",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding unten",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Anlass-Kachel",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild (manuell)",
          "info": "Wenn gesetzt, wird dieses Bild verwendet. Sonst greift das verknüpfte Produkt oder der Auto-Fallback."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Produkt (optional)",
          "info": "Wenn ausgewählt: Bild, Titel und Link werden vom Produkt übernommen, falls kein manuelles Bild gesetzt ist."
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker (kleiner Caps-Text)",
          "default": "Sortiment"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Anlass-Name",
          "default": "Hochzeit"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Blüten-Icon",
          "info": "Standard: passend zum Anlass-Name.",
          "options": [
            { "value": "auto", "label": "Auto (Anlass-Name)" },
            { "value": "peony", "label": "Pfingstrose" },
            { "value": "rose-stem", "label": "Rose" },
            { "value": "sunflower", "label": "Sonnenblume" },
            { "value": "tulip", "label": "Tulpe" },
            { "value": "lavender", "label": "Lavendel" },
            { "value": "wildflower", "label": "Wildblume" },
            { "value": "branch", "label": "Zweig" },
            { "value": "sprig", "label": "Allgemein" }
          ],
          "default": "auto"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Florice Anlässe",
      "category": "Florice",
      "blocks": [
        { "type": "tile", "settings": { "kicker": "Kollektion", "title": "Hochzeit" } },
        { "type": "tile", "settings": { "kicker": "Kollektion", "title": "Geschenk" } },
        { "type": "tile", "settings": { "kicker": "Kollektion", "title": "Trauer" } },
        { "type": "tile", "settings": { "kicker": "Kollektion", "title": "Wohnen" } }
      ]
    }
  ]
}
{% endschema %}
