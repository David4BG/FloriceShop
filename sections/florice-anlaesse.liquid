<div
  class="florice-anlaesse color-{{ section.settings.color_scheme }} gradient"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="florice-anlaesse__head page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="florice-anlaesse__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="florice-anlaesse__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}
      <div class="florice-anlaesse__intro rte">{{ section.settings.intro }}</div>
    {%- endif -%}
  </div>

  <div class="florice-anlaesse__grid page-width">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.link | default: '#' }}"
        class="florice-anlaesse__tile"
        {{ block.shopify_attributes }}
      >
        <div class="florice-anlaesse__media">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 990px) 25vw, 50vw',
                widths: '375, 550, 750, 900',
                alt: block.settings.title
            }}
          {%- else -%}
            {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <span class="florice-anlaesse__number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
        </div>
        <div class="florice-anlaesse__caption">
          <span class="florice-anlaesse__kicker">{{ block.settings.kicker | escape }}</span>
          <span class="florice-anlaesse__name">{{ block.settings.title | escape }}</span>
          <span class="florice-anlaesse__arrow" aria-hidden="true">→</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.florice-anlaesse {
  position: relative;
}

.florice-anlaesse__head {
  text-align: center;
  max-width: 56rem;
  margin: 0 auto 5rem;
  padding: 0 2rem;
}

.florice-anlaesse__eyebrow {
  font-size: 1.1rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  margin: 0 0 1.5rem;
  opacity: 0.65;
  font-weight: 500;
}

.florice-anlaesse__title {
  font-family: var(--font-heading-family);
  font-weight: 300;
  font-size: clamp(3.4rem, 5vw, 5.6rem);
  line-height: 1.05;
  letter-spacing: -0.025em;
  margin: 0 0 2rem;
  word-break: keep-all;
  overflow-wrap: normal;
  hyphens: none;
}

.florice-anlaesse__title em {
  font-style: italic;
  font-weight: 300;
}

.florice-anlaesse__intro {
  font-size: 1.55rem;
  line-height: 1.6;
  opacity: 0.75;
  max-width: 42rem;
  margin: 0 auto;
}

.florice-anlaesse__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
}

.florice-anlaesse__tile {
  position: relative;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  background: transparent;
}

.florice-anlaesse__media {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: rgb(var(--color-background) / 0.6);
}

.florice-anlaesse__media img,
.florice-anlaesse__media svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.9s cubic-bezier(0.16, 0.84, 0.44, 1);
}

.florice-anlaesse__tile:hover .florice-anlaesse__media img {
  transform: scale(1.04);
}

.florice-anlaesse__number {
  position: absolute;
  top: 1.2rem;
  left: 1.4rem;
  font-family: var(--font-heading-family);
  font-style: italic;
  font-size: 1.6rem;
  color: white;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
  letter-spacing: 0.05em;
}

.florice-anlaesse__caption {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: end;
  gap: 0.5rem 1rem;
  padding: 1.8rem 0.3rem 0;
  position: relative;
}

.florice-anlaesse__caption::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: rgb(var(--color-foreground) / 0.22);
}

.florice-anlaesse__kicker {
  grid-column: 1 / 2;
  grid-row: 1;
  font-size: 1rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  opacity: 0.6;
  font-weight: 500;
}

.florice-anlaesse__name {
  grid-column: 1 / 2;
  grid-row: 2;
  font-family: var(--font-heading-family);
  font-style: italic;
  font-weight: 300;
  font-size: 2.2rem;
  letter-spacing: -0.01em;
  line-height: 1.1;
}

.florice-anlaesse__arrow {
  grid-column: 2 / 3;
  grid-row: 2;
  font-size: 1.8rem;
  align-self: end;
  transition: transform 0.3s ease;
}

.florice-anlaesse__tile:hover .florice-anlaesse__arrow {
  transform: translateX(6px);
}

@media screen and (max-width: 989px) {
  .florice-anlaesse__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .florice-anlaesse__head {
    margin-bottom: 3.5rem;
  }
  .florice-anlaesse__name {
    font-size: 1.8rem;
  }
}

@media screen and (max-width: 480px) {
  .florice-anlaesse__grid {
    gap: 0.8rem;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Florice Anlässe",
  "tag": "section",
  "class": "section section-florice-anlaesse",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Kopf"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Für jeden Moment"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Titel",
      "default": "Anlässe, die <em>bleiben.</em>"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro-Text",
      "default": "<p>Vier Sammlungen, jede mit eigener Stimmung. Wähle den Moment — wir wickeln die passende Blüte.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farb-Schema",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding oben",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding unten",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Anlass-Kachel",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker (kleiner Caps-Text)",
          "default": "Kollektion"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Anlass-Name",
          "default": "Hochzeit"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Florice Anlässe",
      "category": "Florice",
      "blocks": [
        { "type": "tile", "settings": { "kicker": "Kollektion", "title": "Hochzeit" } },
        { "type": "tile", "settings": { "kicker": "Kollektion", "title": "Geschenk" } },
        { "type": "tile", "settings": { "kicker": "Kollektion", "title": "Trauer" } },
        { "type": "tile", "settings": { "kicker": "Kollektion", "title": "Wohnen" } }
      ]
    }
  ]
}
{% endschema %}
