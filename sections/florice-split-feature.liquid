<div
  class="florice-split color-{{ section.settings.color_scheme }} gradient florice-split--{{ section.settings.layout }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="florice-split__deco florice-split__deco--corner" aria-hidden="true">
    {% render 'florice-bloom', type: 'sunflower' %}
  </div>
  <div class="florice-split__deco florice-split__deco--accent" aria-hidden="true">
    {% render 'florice-bloom', type: 'wildflower' %}
  </div>

  <div class="florice-split__inner page-width">
    <div class="florice-split__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 990px) 50vw, 100vw',
            widths: '550, 750, 1100, 1400',
            alt: section.settings.title
        }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      {%- if section.settings.image_caption != blank -%}
        <span class="florice-split__caption">{{ section.settings.image_caption | escape }}</span>
      {%- endif -%}
    </div>

    <div class="florice-split__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="florice-split__eyebrow">
          {% render 'florice-bloom', type: 'small' %}
          <span>{{ section.settings.eyebrow | escape }}</span>
        </p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="florice-split__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="florice-split__body rte">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="florice-split__specs">
          {%- for block in section.blocks -%}
            {%- if block.type == 'spec' -%}
              <li class="florice-split__spec" {{ block.shopify_attributes }}>
                <span class="florice-split__spec-label">{{ block.settings.label | escape }}</span>
                <span class="florice-split__spec-value">{{ block.settings.value | escape }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: '#' }}" class="florice-split__cta">
          {{ section.settings.cta_label | escape }}
          <span aria-hidden="true">→</span>
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
.florice-split {
  position: relative;
  overflow: hidden;
}

.florice-split__deco {
  position: absolute;
  pointer-events: none;
  color: rgb(var(--color-foreground));
  z-index: 0;
}

.florice-split__deco--corner {
  top: 6%;
  right: 3%;
  width: 6rem;
  opacity: 0.17;
  transform: rotate(15deg);
}

.florice-split__deco--accent {
  bottom: 4%;
  left: 4%;
  width: 5rem;
  opacity: 0.15;
  transform: rotate(-18deg);
}

.florice-split--right .florice-split__deco--corner {
  right: auto;
  left: 3%;
  transform: rotate(-15deg);
}

.florice-split--right .florice-split__deco--accent {
  left: auto;
  right: 4%;
  transform: rotate(18deg);
}

.florice-split__inner {
  position: relative;
  z-index: 1;
}

@media screen and (max-width: 989px) {
  .florice-split__deco--corner {
    width: 4.4rem;
    opacity: 0.12;
  }
  .florice-split__deco--accent {
    width: 4rem;
    opacity: 0.12;
  }
}

.florice-split__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rem;
  align-items: center;
}

.florice-split--right .florice-split__media {
  order: 2;
}

.florice-split--right .florice-split__content {
  order: 1;
}

.florice-split__media {
  position: relative;
  aspect-ratio: 4 / 5;
  overflow: hidden;
  background: rgb(var(--color-background) / 0.6);
}

.florice-split__media img,
.florice-split__media svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.florice-split__caption {
  position: absolute;
  bottom: 1.2rem;
  left: 1.4rem;
  font-family: var(--font-heading-family);
  font-style: italic;
  font-size: 1.3rem;
  color: white;
  text-shadow: 0 1px 6px rgba(0, 0, 0, 0.45);
}

.florice-split__content {
  max-width: 44rem;
}

.florice-split__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  font-size: 1.1rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  margin: 0 0 1.8rem;
  opacity: 0.7;
  font-weight: 500;
}

.florice-split__eyebrow .florice-bloom {
  opacity: 0.6;
}

.florice-split__title {
  font-family: var(--font-heading-family);
  font-weight: 300;
  font-size: clamp(3.2rem, 4.5vw, 5.4rem);
  line-height: 1.04;
  letter-spacing: -0.025em;
  margin: 0 0 2.5rem;
  color: rgb(var(--color-foreground));
  word-break: keep-all;
  overflow-wrap: normal;
  hyphens: none;
}

.florice-split__title em {
  font-style: italic;
  font-weight: 300;
}

.florice-split__body {
  font-size: 1.6rem;
  line-height: 1.65;
  opacity: 0.82;
  margin: 0 0 2.5rem;
}

.florice-split__body p { margin: 0 0 1.2rem; }
.florice-split__body p:last-child { margin-bottom: 0; }

.florice-split__specs {
  list-style: none;
  padding: 0;
  margin: 0 0 3rem;
  border-top: 1px solid rgb(var(--color-foreground) / 0.18);
}

.florice-split__spec {
  display: grid;
  grid-template-columns: 14rem 1fr;
  gap: 2rem;
  padding: 1.4rem 0;
  border-bottom: 1px solid rgb(var(--color-foreground) / 0.12);
}

.florice-split__spec-label {
  font-size: 1.05rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  opacity: 0.6;
  font-weight: 500;
}

.florice-split__spec-value {
  font-family: var(--font-heading-family);
  font-style: italic;
  font-size: 1.6rem;
  font-weight: 300;
}

.florice-split__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1.6rem 2.6rem;
  background: rgb(var(--color-button));
  color: rgb(var(--color-button-text));
  text-decoration: none;
  font-size: 1.15rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  font-weight: 500;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.florice-split__cta:hover {
  transform: translateY(-1px);
  opacity: 0.92;
}

.florice-split__cta span {
  transition: transform 0.25s ease;
}

.florice-split__cta:hover span {
  transform: translateX(4px);
}

@media screen and (max-width: 989px) {
  .florice-split__inner {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .florice-split--right .florice-split__media,
  .florice-split--right .florice-split__content {
    order: unset;
  }
  .florice-split__spec {
    grid-template-columns: 10rem 1fr;
    gap: 1.5rem;
  }
  .florice-split__title {
    font-size: clamp(2.8rem, 7vw, 4rem);
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Florice Split Feature",
  "tag": "section",
  "class": "section section-florice-split",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Bild"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild"
    },
    {
      "type": "text",
      "id": "image_caption",
      "label": "Bildunterschrift (kursive Notiz)",
      "default": "Foto: Atelier-Tisch · Tageslicht"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Bildposition",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Material"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Titel",
      "default": "Draht, Faden, <em>Geduld.</em>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Florice-Blüten entstehen aus weichem Chenille-Draht. Kein Plastik, das nach Plastik aussieht. Stattdessen ein Material, das die Haptik echter Petalen erinnert — und Jahre überdauert.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA-Text",
      "default": "Mehr über das Atelier"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA-Link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farb-Schema",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "label": "Padding oben",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "label": "Padding unten",
      "default": 120
    }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Spec-Zeile",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label (Caps)",
          "default": "Material"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Wert (kursiv)",
          "default": "Chenille-Draht · Textil"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Florice Split Feature",
      "category": "Florice",
      "blocks": [
        { "type": "spec", "settings": { "label": "Material", "value": "Chenille-Draht · Textil" } },
        { "type": "spec", "settings": { "label": "Herkunft", "value": "Manufaktur in Deutschland" } },
        { "type": "spec", "settings": { "label": "Haltbarkeit", "value": "Mehrere Jahre" } }
      ]
    }
  ]
}
{% endschema %}
