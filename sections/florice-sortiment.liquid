<div
  class="florice-sortiment color-{{ section.settings.color_scheme }} gradient"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="florice-sortiment__scatter" aria-hidden="true">
    <span class="florice-sortiment__sb florice-sortiment__sb--tl">{% render 'florice-bloom', type: 'wildflower' %}</span>
    <span class="florice-sortiment__sb florice-sortiment__sb--tr">{% render 'florice-bloom', type: 'tulip' %}</span>
    <span class="florice-sortiment__sb florice-sortiment__sb--bl">{% render 'florice-bloom', type: 'branch' %}</span>
    <span class="florice-sortiment__sb florice-sortiment__sb--br">{% render 'florice-bloom', type: 'sprig' %}</span>
  </div>

  <div class="florice-sortiment__head page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="florice-sortiment__eyebrow">
        {% render 'florice-bloom', type: 'small' %}
        <span>{{ section.settings.eyebrow | escape }}</span>
        {% render 'florice-bloom', type: 'small' %}
      </p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="florice-sortiment__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}
      <div class="florice-sortiment__intro rte">{{ section.settings.intro }}</div>
    {%- endif -%}
    <div class="florice-sortiment__divider" aria-hidden="true">
      {% render 'florice-bloom', type: 'divider' %}
    </div>
  </div>

  <div class="florice-sortiment__grid page-width">
    {%- for block in section.blocks -%}
      {%- liquid
        assign icon_override = block.settings.icon
        assign latin_lower = block.settings.latin | downcase
        if icon_override != blank and icon_override != 'auto'
          assign bloom_icon = icon_override
        elsif latin_lower contains 'paeonia'
          assign bloom_icon = 'peony'
        elsif latin_lower contains 'rosa'
          assign bloom_icon = 'rose-stem'
        elsif latin_lower contains 'helianthus'
          assign bloom_icon = 'sunflower'
        elsif latin_lower contains 'tulipa'
          assign bloom_icon = 'tulip'
        elsif latin_lower contains 'lavandula'
          assign bloom_icon = 'lavender'
        elsif latin_lower contains 'eustoma' or latin_lower contains 'cosmos'
          assign bloom_icon = 'wildflower'
        else
          assign bloom_icon = 'sprig'
        endif
      -%}

      <a
        href="{{ block.settings.link | default: '#' }}"
        class="florice-sortiment__item florice-sortiment__item--{{ bloom_icon }}"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.badge != blank -%}
          <span class="florice-sortiment__badge">{{ block.settings.badge | escape }}</span>
        {%- endif -%}

        <div class="florice-sortiment__icon" data-bloom="{{ bloom_icon }}">
          {% render 'florice-bloom', type: bloom_icon %}
        </div>

        <span class="florice-sortiment__latin">{{ block.settings.latin | escape }}</span>
        <h3 class="florice-sortiment__name">{{ block.settings.name | escape }}</h3>
        <p class="florice-sortiment__meaning">{{ block.settings.meaning | escape }}</p>

        <span class="florice-sortiment__cta">
          <span>{{ section.settings.item_cta | default: 'Ansehen' | escape }}</span>
          <span aria-hidden="true">→</span>
        </span>
      </a>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.florice-sortiment {
  position: relative;
  overflow: hidden;
}

.florice-sortiment__scatter {
  position: absolute;
  inset: 0;
  pointer-events: none;
  color: rgb(var(--color-foreground));
  z-index: 0;
}

.florice-sortiment__sb {
  position: absolute;
  opacity: 0.13;
  display: block;
}

.florice-sortiment__sb--tl {
  top: 6%;
  left: 4%;
  width: 5.2rem;
  transform: rotate(-15deg);
}

.florice-sortiment__sb--tr {
  top: 12%;
  right: 5%;
  width: 5rem;
  transform: rotate(20deg);
}

.florice-sortiment__sb--bl {
  bottom: 10%;
  left: 6%;
  width: 5.4rem;
  transform: rotate(8deg);
}

.florice-sortiment__sb--br {
  bottom: 6%;
  right: 4%;
  width: 5rem;
  transform: rotate(-12deg);
}

.florice-sortiment__head,
.florice-sortiment__grid {
  position: relative;
  z-index: 1;
}

@media screen and (max-width: 749px) {
  .florice-sortiment__sb {
    width: 3.6rem !important;
    opacity: 0.1;
  }
  .florice-sortiment__sb--tl,
  .florice-sortiment__sb--tr {
    top: 3%;
  }
  .florice-sortiment__sb--bl,
  .florice-sortiment__sb--br {
    bottom: 3%;
  }
}

.florice-sortiment__head {
  text-align: center;
  max-width: 60rem;
  margin: 0 auto 5rem;
  padding: 0 2rem;
}

.florice-sortiment__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 1.2rem;
  font-size: 1.05rem;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  margin: 0 0 2rem;
  opacity: 0.7;
  font-weight: 500;
}

.florice-sortiment__eyebrow .florice-bloom {
  opacity: 0.55;
}

.florice-sortiment__title {
  font-family: var(--font-heading-family);
  font-weight: 300;
  font-size: clamp(3.4rem, 5vw, 5.6rem);
  line-height: 1.05;
  letter-spacing: -0.025em;
  margin: 0 0 2rem;
  word-break: keep-all;
  overflow-wrap: normal;
  hyphens: none;
}

.florice-sortiment__title em {
  font-style: italic;
  font-weight: 300;
}

.florice-sortiment__intro {
  font-size: 1.55rem;
  line-height: 1.6;
  opacity: 0.78;
  max-width: 44rem;
  margin: 0 auto 2.5rem;
}

.florice-sortiment__divider {
  margin: 1rem auto 0;
  opacity: 0.7;
  text-align: center;
}

.florice-sortiment__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.florice-sortiment__item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  text-decoration: none;
  color: inherit;
  border: 1px solid rgb(var(--color-foreground) / 0.22);
  padding: 3.5rem 2.5rem 3rem;
  background: transparent;
  transition: background 0.3s ease, transform 0.3s ease;
  overflow: hidden;
}

.florice-sortiment__item::before {
  content: "";
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 2px;
  background: rgb(var(--color-foreground));
  transition: width 0.4s cubic-bezier(0.16, 0.84, 0.44, 1);
}

.florice-sortiment__item:hover {
  background: rgb(var(--color-foreground) / 0.04);
  transform: translateY(-2px);
}

.florice-sortiment__item:hover::before {
  width: 100%;
}

.florice-sortiment__badge {
  position: absolute;
  top: 1.4rem;
  right: 1.4rem;
  font-size: 0.9rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 600;
  padding: 0.3rem 0.7rem;
  background: rgb(var(--color-foreground));
  color: rgb(var(--color-background));
}

.florice-sortiment__icon {
  margin: 0 0 1.8rem;
  opacity: 0.85;
  transition: transform 0.5s cubic-bezier(0.16, 0.84, 0.44, 1);
  min-height: 5.6rem;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.florice-sortiment__icon .florice-bloom {
  width: 4rem;
  height: 5.6rem;
}

.florice-sortiment__icon[data-bloom="peony"] .florice-bloom,
.florice-sortiment__icon[data-bloom="rose-stem"] .florice-bloom {
  width: 4.4rem;
  height: 5.8rem;
}

.florice-sortiment__icon[data-bloom="lavender"] .florice-bloom {
  width: 3.2rem;
}

.florice-sortiment__item:hover .florice-sortiment__icon {
  transform: rotate(-4deg) translateY(-2px);
}

.florice-sortiment__latin {
  font-size: 1rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  font-weight: 500;
  opacity: 0.55;
  font-style: italic;
  margin: 0 0 0.6rem;
}

.florice-sortiment__name {
  font-family: var(--font-heading-family);
  font-weight: 300;
  font-size: 2.6rem;
  line-height: 1.05;
  letter-spacing: -0.015em;
  margin: 0 0 1.4rem;
}

.florice-sortiment__meaning {
  font-family: var(--font-heading-family);
  font-style: italic;
  font-size: 1.4rem;
  line-height: 1.4;
  opacity: 0.72;
  margin: 0 0 2rem;
  max-width: 22rem;
}

.florice-sortiment__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 1.05rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 600;
  opacity: 0.85;
}

.florice-sortiment__cta span:last-child {
  transition: transform 0.25s ease;
}

.florice-sortiment__item:hover .florice-sortiment__cta span:last-child {
  transform: translateX(5px);
}

@media screen and (max-width: 989px) {
  .florice-sortiment__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .florice-sortiment__head {
    margin-bottom: 3.5rem;
  }
  .florice-sortiment__item {
    padding: 3rem 1.8rem 2.5rem;
  }
  .florice-sortiment__name {
    font-size: 2.2rem;
  }
}

@media screen and (max-width: 480px) {
  .florice-sortiment__grid {
    grid-template-columns: 1fr;
  }
  .florice-sortiment__item {
    padding: 2.8rem 2rem 2.4rem;
  }
  .florice-sortiment__latin {
    letter-spacing: 0.2em;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Florice Sortiment",
  "tag": "section",
  "class": "section section-florice-sortiment",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Kopf"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Sortiment · Florice"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Titel",
      "default": "Blütensorten aus dem <em>Atelier.</em>"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro-Text",
      "default": "<p>Jede Sorte mit eigenem Charakter und eigener Bedeutung. Handgewickelt nach botanischem Vorbild — und für immer.</p>"
    },
    {
      "type": "text",
      "id": "item_cta",
      "label": "Item-CTA-Text",
      "default": "Ansehen"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farb-Schema",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "label": "Padding oben",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "label": "Padding unten",
      "default": 120
    }
  ],
  "blocks": [
    {
      "type": "sorte",
      "name": "Blütensorte",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "latin",
          "label": "Lateinischer Name (Caps Italic)",
          "default": "Paeonia"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Deutscher Name",
          "default": "Pfingstrose"
        },
        {
          "type": "text",
          "id": "meaning",
          "label": "Bedeutung / Stimmung",
          "default": "Wohlstand · Hingabe"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (optional)",
          "info": "z. B. „Saison\", „Bestseller\", „Neu\""
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Blüten-Icon",
          "info": "Standard: passend zum Latein-Namen.",
          "options": [
            { "value": "auto", "label": "Auto (Latein-Name)" },
            { "value": "peony", "label": "Pfingstrose" },
            { "value": "rose-stem", "label": "Rose" },
            { "value": "sunflower", "label": "Sonnenblume" },
            { "value": "tulip", "label": "Tulpe" },
            { "value": "lavender", "label": "Lavendel" },
            { "value": "wildflower", "label": "Wildblume" },
            { "value": "branch", "label": "Zweig" },
            { "value": "sprig", "label": "Allgemein (Sprig)" }
          ],
          "default": "auto"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Florice Sortiment",
      "category": "Florice",
      "blocks": [
        {
          "type": "sorte",
          "settings": {
            "latin": "Paeonia",
            "name": "Pfingstrose",
            "meaning": "Wohlstand · Hingabe",
            "badge": "Saison"
          }
        },
        {
          "type": "sorte",
          "settings": {
            "latin": "Rosa",
            "name": "Rose",
            "meaning": "Liebe · Leidenschaft"
          }
        },
        {
          "type": "sorte",
          "settings": {
            "latin": "Helianthus",
            "name": "Sonnenblume",
            "meaning": "Wärme · Lebensfreude"
          }
        },
        {
          "type": "sorte",
          "settings": {
            "latin": "Tulipa",
            "name": "Tulpe",
            "meaning": "Eleganz · Frühling"
          }
        },
        {
          "type": "sorte",
          "settings": {
            "latin": "Lavandula",
            "name": "Lavendel",
            "meaning": "Ruhe · Klarheit"
          }
        },
        {
          "type": "sorte",
          "settings": {
            "latin": "Eustoma",
            "name": "Wildblume",
            "meaning": "Charme · Natürlichkeit"
          }
        }
      ]
    }
  ]
}
{% endschema %}
