<div
  class="florice-atelier color-{{ section.settings.color_scheme }} gradient"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="florice-atelier__inner page-width">
    <div class="florice-atelier__text">
      {%- if section.settings.eyebrow != blank -%}
        <p class="florice-atelier__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="florice-atelier__title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="florice-atelier__body rte">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.settings.link_label != blank -%}
        <a
          href="{{ section.settings.link_url | default: '#' }}"
          class="florice-atelier__link"
        >
          {{ section.settings.link_label | escape }}
          <span aria-hidden="true">→</span>
        </a>
      {%- endif -%}
    </div>

    <div class="florice-atelier__images">
      {%- for block in section.blocks -%}
        {%- if block.type == 'image' -%}
          <figure
            class="florice-atelier__img florice-atelier__img--{{ forloop.index }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 990px) 25vw, 50vw',
                  widths: '375, 550, 750, 800',
                  alt: block.settings.image.alt
              }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </figure>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
.florice-atelier {
  position: relative;
  overflow: hidden;
}

.florice-atelier__inner {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 4rem;
  align-items: center;
}

.florice-atelier__text {
  max-width: 38rem;
}

.florice-atelier__eyebrow {
  font-size: 1.1rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  margin: 0 0 2rem;
  opacity: 0.65;
  font-weight: 500;
}

.florice-atelier__title {
  font-family: var(--font-heading-family);
  font-style: italic;
  font-weight: 300;
  font-size: clamp(4rem, 5vw, 6.4rem);
  line-height: 1;
  letter-spacing: -0.025em;
  margin: 0 0 2.5rem;
  color: rgb(var(--color-foreground));
  word-break: keep-all;
  overflow-wrap: normal;
  hyphens: none;
}

.florice-atelier__title em {
  font-style: italic;
  font-weight: 300;
}

.florice-atelier__body {
  font-size: 1.6rem;
  line-height: 1.6;
  opacity: 0.8;
  margin: 0 0 2.5rem;
}

.florice-atelier__body p {
  margin: 0 0 1rem;
}

.florice-atelier__body p:last-child {
  margin-bottom: 0;
}

.florice-atelier__link {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 1.2rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 500;
  color: rgb(var(--color-foreground));
  text-decoration: none;
  border-bottom: 1px solid rgb(var(--color-foreground));
  padding-bottom: 0.3rem;
  transition: opacity 0.2s ease;
}

.florice-atelier__link:hover {
  opacity: 0.65;
}

.florice-atelier__link span {
  transition: transform 0.25s ease;
}

.florice-atelier__link:hover span {
  transform: translateX(4px);
}

.florice-atelier__images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.florice-atelier__img {
  margin: 0;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: rgb(var(--color-background) / 0.6);
}

.florice-atelier__img--2 {
  margin-top: 4rem;
}

.florice-atelier__img--3 {
  margin-top: -2rem;
}

.florice-atelier__img img,
.florice-atelier__img svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.florice-atelier__img--placeholder svg {
  opacity: 0.4;
}

@media screen and (max-width: 989px) {
  .florice-atelier__inner {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .florice-atelier__images {
    gap: 0.75rem;
  }

  .florice-atelier__img--2 {
    margin-top: 1.5rem;
  }

  .florice-atelier__img--3 {
    margin-top: -1rem;
  }

  .florice-atelier__title {
    font-size: clamp(3.2rem, 9vw, 4.8rem);
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Florice Atelier Strip",
  "tag": "section",
  "class": "section section-florice-atelier",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (Caps-Text über Titel)",
      "default": "Aus dem Atelier"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Titel",
      "info": "Mit <em>...</em> um einzelne Wörter kursiv zu setzen.",
      "default": "Vier Stunden für eine <em>einzige</em> Blüte."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body-Text",
      "default": "<p>Pfeifenreiniger, Draht, ein wenig Geduld. Keine Maschine, keine Massenware. Florice-Blumen werden Stiel für Stiel gewickelt — am Tisch, mit Tageslicht, ohne Eile.</p>"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link-Text",
      "default": "So entsteht eine Florice"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link-Ziel"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farb-Schema",
      "default": "scheme-3",
      "info": "Olive-Schema (scheme-3 oder scheme-4) wirkt gut für diesen Block."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding oben",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding unten",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Bild",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Florice Atelier Strip",
      "category": "Florice",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
