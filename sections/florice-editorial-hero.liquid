<div
  class="florice-hero color-{{ section.settings.color_scheme }} gradient florice-hero--{{ section.settings.image_position }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="florice-hero__bloom-bg florice-hero__bloom-bg--top" aria-hidden="true">
    {% render 'florice-bloom', type: 'spray' %}
  </div>
  <div class="florice-hero__bloom-bg florice-hero__bloom-bg--bottom" aria-hidden="true">
    {% render 'florice-bloom', type: 'peony' %}
  </div>
  <div class="florice-hero__inner">
    <div class="florice-hero__image">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1600
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '(min-width: 990px) 55vw, 100vw',
            widths: '375, 550, 750, 1100, 1500, 1600',
            alt: section.settings.image.alt
        }}
      {%- else -%}
        <img
          src="{{ section.settings.fallback_image_url | default: 'https://images.unsplash.com/photo-1597848212624-a19eb35e2651?auto=format&fit=crop&w=1600&q=80' }}"
          alt="{{ section.settings.image_caption | default: 'Florice Bouquet' | escape }}"
          loading="eager"
          fetchpriority="high"
          width="1600"
          height="2000"
        >
      {%- endif -%}
      {%- if section.settings.image_caption != blank -%}
        <span class="florice-hero__caption">{{ section.settings.image_caption }}</span>
      {%- endif -%}
    </div>

    <div class="florice-hero__text">
      {%- if section.settings.kicker != blank -%}
        <p class="florice-hero__kicker">
          {% render 'florice-bloom', type: 'small' %}
          <span>{{ section.settings.kicker }}</span>
          {% render 'florice-bloom', type: 'small' %}
        </p>
      {%- endif -%}

      {%- if section.settings.headline != blank -%}
        <h1 class="florice-hero__headline">{{ section.settings.headline }}</h1>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <div class="florice-hero__sub rte">{{ section.settings.subtext }}</div>
      {%- endif -%}

      {%- if section.settings.primary_button_label != blank or section.settings.secondary_link_label != blank -%}
        <div class="florice-hero__cta-group">
          {%- if section.settings.primary_button_label != blank -%}
            <a
              href="{{ section.settings.primary_button_link | default: '#' }}"
              class="florice-hero__cta"
            >
              {{ section.settings.primary_button_label | escape }}
              <span class="florice-hero__cta-arrow" aria-hidden="true">→</span>
            </a>
          {%- endif -%}

          {%- if section.settings.secondary_link_label != blank -%}
            <a
              href="{{ section.settings.secondary_link_link | default: '#' }}"
              class="florice-hero__story-link"
            >
              {{ section.settings.secondary_link_label | escape }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
.florice-hero {
  position: relative;
  overflow: hidden;
}

.florice-hero__bloom-bg {
  position: absolute;
  pointer-events: none;
  color: rgb(var(--color-foreground));
  z-index: 0;
}

.florice-hero__bloom-bg--top {
  top: -10%;
  right: -8%;
  width: 56%;
  max-width: 64rem;
  aspect-ratio: 1;
  opacity: 0.11;
}

.florice-hero__bloom-bg--bottom {
  bottom: 4%;
  left: -2%;
  width: 14rem;
  opacity: 0.13;
  transform: rotate(-15deg);
}

.florice-hero--right .florice-hero__bloom-bg--top {
  right: auto;
  left: -8%;
}

.florice-hero--right .florice-hero__bloom-bg--bottom {
  left: auto;
  right: -2%;
  transform: rotate(15deg);
}

@media screen and (max-width: 1099px) {
  .florice-hero__bloom-bg--top {
    top: -4%;
    right: -28%;
    width: 75%;
    opacity: 0.09;
  }
  .florice-hero__bloom-bg--bottom {
    display: none;
  }
}

@media screen and (max-width: 600px) {
  .florice-hero__bloom-bg--top {
    top: -2%;
    right: -40%;
    width: 90%;
    opacity: 0.08;
  }
}

.florice-hero__inner {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1.05fr 1fr;
  gap: 4rem;
  align-items: center;
  max-width: var(--page-width, 144rem);
  margin: 0 auto;
  padding: 0 4rem;
  min-height: 90vh;
}

.florice-hero--right .florice-hero__inner {
  grid-template-columns: 1fr 1.05fr;
}

.florice-hero--right .florice-hero__image {
  order: 2;
  margin-left: 0;
  margin-right: -4rem;
}

.florice-hero--right .florice-hero__text {
  order: 1;
  padding-left: 0;
}

.florice-hero__image {
  position: relative;
  aspect-ratio: 4 / 5;
  overflow: hidden;
  margin-left: -4rem;
  background: rgb(var(--color-foreground) / 0.06);
}

.florice-hero__image img,
.florice-hero__image svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
}

.florice-hero__image--placeholder svg {
  opacity: 0.4;
}

.florice-hero__caption {
  position: absolute;
  bottom: 1.25rem;
  right: 1.25rem;
  font-size: 1.1rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: white;
  background: rgba(31, 26, 23, 0.55);
  -webkit-backdrop-filter: blur(4px);
  backdrop-filter: blur(4px);
  padding: 0.5rem 0.75rem;
  font-weight: 500;
}

.florice-hero__text {
  max-width: 30rem;
  padding-right: 0;
}

.florice-hero__kicker {
  display: inline-flex;
  align-items: center;
  gap: 1.1rem;
  font-size: 1.1rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  margin: 0 0 2rem;
  opacity: 0.75;
  font-weight: 500;
}

.florice-hero__kicker .florice-bloom {
  opacity: 0.55;
}

.florice-hero__headline {
  font-family: var(--font-heading-family);
  font-weight: 300;
  font-style: normal;
  font-variation-settings: "opsz" 144;
  font-size: clamp(3.5rem, 8vw, 7rem);
  line-height: 0.92;
  letter-spacing: -0.035em;
  margin: 0 0 2.5rem;
  color: rgb(var(--color-foreground));
  word-break: keep-all;
  overflow-wrap: normal;
  hyphens: none;
}

.florice-hero__headline em {
  font-style: italic;
  font-weight: 300;
}

.florice-hero__sub {
  font-size: 1.7rem;
  line-height: 1.55;
  max-width: 24rem;
  margin: 0 0 2.5rem;
  opacity: 0.8;
}

.florice-hero__sub p {
  margin: 0 0 1rem;
}

.florice-hero__sub p:last-child {
  margin-bottom: 0;
}

.florice-hero__cta-group {
  display: flex;
  align-items: center;
  gap: 2rem;
  flex-wrap: wrap;
}

.florice-hero__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1.8rem 3rem;
  background: rgb(var(--color-button));
  color: rgb(var(--color-button-text));
  text-decoration: none;
  font-size: 1.2rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  font-weight: 500;
  transition: transform 0.2s ease, opacity 0.2s ease;
  border: 0;
}

.florice-hero__cta:hover {
  transform: translateY(-1px);
  opacity: 0.92;
}

.florice-hero__cta-arrow {
  display: inline-block;
  transition: transform 0.25s ease;
}

.florice-hero__cta:hover .florice-hero__cta-arrow {
  transform: translateX(4px);
}

.florice-hero__story-link {
  font-size: 1.2rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgb(var(--color-foreground));
  text-decoration: none;
  border-bottom: 1px solid rgb(var(--color-foreground));
  padding-bottom: 0.3rem;
  font-weight: 500;
}

.florice-hero__story-link:hover {
  opacity: 0.65;
}

@media screen and (max-width: 1099px) {
  .florice-hero__inner {
    grid-template-columns: 1fr;
    gap: 2.5rem;
    min-height: auto;
    padding: 0;
  }

  .florice-hero__image,
  .florice-hero--right .florice-hero__image {
    margin: 0;
    aspect-ratio: 4 / 3;
    order: 1;
  }

  .florice-hero__text,
  .florice-hero--right .florice-hero__text {
    padding: 0 1.5rem 2rem;
    order: 2;
    max-width: none;
  }

  .florice-hero__headline {
    font-size: clamp(3.6rem, 10vw, 6.4rem);
  }

  .florice-hero__sub {
    font-size: 1.5rem;
    max-width: none;
  }

  .florice-hero__cta-group {
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Florice Editorial Hero",
  "tag": "section",
  "class": "section section-florice-hero",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Bildbereich"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero-Bild",
      "info": "Wenn leer, wird ein Demo-Foto (Unsplash) angezeigt. Lade hier dein eigenes Florice-Foto hoch, sobald verfügbar."
    },
    {
      "type": "text",
      "id": "fallback_image_url",
      "label": "Fallback-Bild-URL",
      "info": "Wird nur genutzt, wenn kein Hero-Bild hochgeladen ist. Standard: Sonnenblumen-Bouquet von Unsplash.",
      "default": "https://images.unsplash.com/photo-1597848212624-a19eb35e2651?auto=format&fit=crop&w=1600&q=80"
    },
    {
      "type": "text",
      "id": "image_caption",
      "label": "Bild-Bildunterschrift (oben rechts auf dem Bild)",
      "info": "Optional. Z. B. 'Ewige Sonnenblumen · Bouquet'"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Bildposition",
      "options": [
        { "value": "left", "label": "Links (überläuft links)" },
        { "value": "right", "label": "Rechts (überläuft rechts)" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (Caps-Text über Headline)",
      "default": "Handgefertigte Kunstblumen — Manufaktur"
    },
    {
      "type": "inline_richtext",
      "id": "headline",
      "label": "Headline",
      "info": "Mit <em>...</em> um einzelne Wörter kursiv zu setzen.",
      "default": "Blumen, <em>die bleiben.</em>"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Sub-Text",
      "default": "<p>Stunden Geduld, eine Hand, ein Faden. Jede Florice-Blume entsteht einzeln — kein Stiel ist wie der andere. Geschenkt für immer, nicht für eine Woche.</p>"
    },
    {
      "type": "header",
      "content": "Aktionen"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primärer Button: Text",
      "default": "Kollektion entdecken"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primärer Button: Link"
    },
    {
      "type": "text",
      "id": "secondary_link_label",
      "label": "Sekundärer Link: Text",
      "default": "Unsere Geschichte"
    },
    {
      "type": "url",
      "id": "secondary_link_link",
      "label": "Sekundärer Link: Link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farb-Schema",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding oben",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding unten",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Florice Editorial Hero",
      "category": "Florice"
    }
  ]
}
{% endschema %}
