{%- liquid
  assign bloom_type = type | default: 'small'
  assign bloom_class = class | default: ''
-%}

{%- case bloom_type -%}
  {%- when 'small' -%}
    <svg
      class="florice-bloom florice-bloom--small {{ bloom_class }}"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="0.7"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
      style="display:inline-block;vertical-align:middle;flex-shrink:0;width:1.6rem;height:1.6rem;"
    >
      <circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none"/>
      <ellipse cx="12" cy="6.5" rx="2.2" ry="4"/>
      <ellipse cx="12" cy="6.5" rx="2.2" ry="4" transform="rotate(60 12 12)"/>
      <ellipse cx="12" cy="6.5" rx="2.2" ry="4" transform="rotate(120 12 12)"/>
      <ellipse cx="12" cy="6.5" rx="2.2" ry="4" transform="rotate(180 12 12)"/>
      <ellipse cx="12" cy="6.5" rx="2.2" ry="4" transform="rotate(240 12 12)"/>
      <ellipse cx="12" cy="6.5" rx="2.2" ry="4" transform="rotate(300 12 12)"/>
    </svg>

  {%- when 'sprig' -%}
    <svg
      class="florice-bloom florice-bloom--sprig {{ bloom_class }}"
      viewBox="0 0 24 32"
      fill="none"
      stroke="currentColor"
      stroke-width="0.7"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
      style="display:inline-block;vertical-align:middle;flex-shrink:0;width:1.5rem;height:2rem;"
    >
      <path d="M12 32 L12 6"/>
      <circle cx="12" cy="4" r="1.4" fill="currentColor" stroke="none"/>
      <ellipse cx="12" cy="2.5" rx="1.6" ry="3"/>
      <ellipse cx="12" cy="2.5" rx="1.6" ry="3" transform="rotate(72 12 4)"/>
      <ellipse cx="12" cy="2.5" rx="1.6" ry="3" transform="rotate(144 12 4)"/>
      <ellipse cx="12" cy="2.5" rx="1.6" ry="3" transform="rotate(216 12 4)"/>
      <ellipse cx="12" cy="2.5" rx="1.6" ry="3" transform="rotate(288 12 4)"/>
      <path d="M12 14 Q7 13 5 18" stroke-width="0.6"/>
      <ellipse cx="6" cy="16" rx="2.5" ry="1.2" transform="rotate(-30 6 16)"/>
      <path d="M12 22 Q17 21 19 26" stroke-width="0.6"/>
      <ellipse cx="18" cy="24" rx="2.5" ry="1.2" transform="rotate(30 18 24)"/>
    </svg>

  {%- when 'divider' -%}
    <svg
      class="florice-bloom florice-bloom--divider {{ bloom_class }}"
      viewBox="0 0 240 24"
      fill="none"
      stroke="currentColor"
      stroke-width="0.6"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
      style="display:block;width:100%;max-width:24rem;height:2.4rem;margin:0 auto;"
    >
      <line x1="0" y1="12" x2="92" y2="12" opacity="0.45"/>
      <line x1="148" y1="12" x2="240" y2="12" opacity="0.45"/>
      <g transform="translate(110 0)">
        <circle cx="10" cy="12" r="1.1" fill="currentColor" stroke="none"/>
        <ellipse cx="10" cy="7" rx="1.8" ry="3.3"/>
        <ellipse cx="10" cy="7" rx="1.8" ry="3.3" transform="rotate(60 10 12)"/>
        <ellipse cx="10" cy="7" rx="1.8" ry="3.3" transform="rotate(120 10 12)"/>
        <ellipse cx="10" cy="7" rx="1.8" ry="3.3" transform="rotate(180 10 12)"/>
        <ellipse cx="10" cy="7" rx="1.8" ry="3.3" transform="rotate(240 10 12)"/>
        <ellipse cx="10" cy="7" rx="1.8" ry="3.3" transform="rotate(300 10 12)"/>
      </g>
      <ellipse cx="98" cy="12" rx="3.5" ry="1.4" transform="rotate(-12 98 12)" opacity="0.55"/>
      <ellipse cx="142" cy="12" rx="3.5" ry="1.4" transform="rotate(12 142 12)" opacity="0.55"/>
    </svg>

  {%- when 'large' -%}
    <svg
      class="florice-bloom florice-bloom--large {{ bloom_class }}"
      viewBox="0 0 320 320"
      fill="none"
      stroke="currentColor"
      stroke-width="0.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
      style="display:block;width:100%;height:100%;"
    >
      <g transform="translate(160 160)">
        <circle cx="0" cy="0" r="6" fill="currentColor" stroke="none"/>
        <g opacity="0.85">
          <ellipse cx="0" cy="-65" rx="32" ry="60"/>
          <ellipse cx="0" cy="-65" rx="32" ry="60" transform="rotate(36)"/>
          <ellipse cx="0" cy="-65" rx="32" ry="60" transform="rotate(72)"/>
          <ellipse cx="0" cy="-65" rx="32" ry="60" transform="rotate(108)"/>
          <ellipse cx="0" cy="-65" rx="32" ry="60" transform="rotate(144)"/>
          <ellipse cx="0" cy="-65" rx="32" ry="60" transform="rotate(180)"/>
          <ellipse cx="0" cy="-65" rx="32" ry="60" transform="rotate(216)"/>
          <ellipse cx="0" cy="-65" rx="32" ry="60" transform="rotate(252)"/>
          <ellipse cx="0" cy="-65" rx="32" ry="60" transform="rotate(288)"/>
          <ellipse cx="0" cy="-65" rx="32" ry="60" transform="rotate(324)"/>
        </g>
        <g>
          <ellipse cx="0" cy="-38" rx="20" ry="38"/>
          <ellipse cx="0" cy="-38" rx="20" ry="38" transform="rotate(60)"/>
          <ellipse cx="0" cy="-38" rx="20" ry="38" transform="rotate(120)"/>
          <ellipse cx="0" cy="-38" rx="20" ry="38" transform="rotate(180)"/>
          <ellipse cx="0" cy="-38" rx="20" ry="38" transform="rotate(240)"/>
          <ellipse cx="0" cy="-38" rx="20" ry="38" transform="rotate(300)"/>
        </g>
        <g>
          <ellipse cx="0" cy="-18" rx="10" ry="20"/>
          <ellipse cx="0" cy="-18" rx="10" ry="20" transform="rotate(72)"/>
          <ellipse cx="0" cy="-18" rx="10" ry="20" transform="rotate(144)"/>
          <ellipse cx="0" cy="-18" rx="10" ry="20" transform="rotate(216)"/>
          <ellipse cx="0" cy="-18" rx="10" ry="20" transform="rotate(288)"/>
        </g>
      </g>
    </svg>
{%- endcase -%}
